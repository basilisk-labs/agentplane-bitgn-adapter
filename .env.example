# BitGN host.
BITGN_HOST=https://api.bitgn.com

# PAC1 uses bitgn/pac1-dev for warmup and bitgn/pac1-prod for production.
BENCHMARK_ID=bitgn/pac1-dev
BITGN_RUNTIME=pcm

# ECOM uses bitgn/ecom1-dev and runtime ecom.
# BENCHMARK_ID=bitgn/ecom1-dev
# BITGN_RUNTIME=ecom

# Required for official BitGN benchmark runs. Sandbox/playground flows may not need it.
BITGN_API_KEY=

# Codex can use ChatGPT OAuth if `codex login` is already complete.
# If you prefer API-key auth, export OPENAI_API_KEY before running.
MODEL_ID=gpt-5.4

# Optional trial filtering for cheap smoke runs.
# TASKS=t01 t04
